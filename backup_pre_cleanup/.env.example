# Example environment variables for local development
ENVIRONMENT=development
API_HOST=127.0.0.1
API_PORT=5000
DATABASE_URL=mysql+aiomysql://ai_user:StrongPassword123@localhost/ai_assistant
APP_TIMEZONE=Asia/Kolkata
JWT_SECRET_KEY=
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=${REDIS_URL}
GOOGLE_API_KEY=
GOOGLE_CLIENT_SECRETS_FILE=backend/credentials.json
GOOGLE_TOKEN_FILE=backend/token.json
ENABLE_JWT_AUTH=false
STARTUP_VALIDATE_GOOGLE_AUTH=false
GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro
GEMINI_TEMPERATURE=0.3
LLM_TIMEOUT_SECONDS=10.0
API_HOST=127.0.0.1
API_PORT=5000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
DATABASE_URL=mysql+aiomysql://root:root@localhost:3306/yashraj_ai
RATE_LIMIT_PER_MINUTE=60
