ENVIRONMENT=development
FRONTEND_ORIGIN=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
# For local development you can use SQLite:
# DATABASE_URL=sqlite+aiosqlite:///./dev_local.db
DATABASE_URL=your_database_url_here
GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MODEL_CANDIDATES=["gemini-1.5-pro"]
GEMINI_TEMPERATURE=0.3
LLM_TIMEOUT_SECONDS=1.5
STARTUP_VALIDATE_GOOGLE_AUTH=false
RATE_LIMIT_PER_MINUTE=60
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
API_HOST=127.0.0.1
API_PORT=5000
APP_TIMEZONE=Asia/Kolkata
GOOGLE_CLIENT_SECRETS_FILE=path/to/credentials.json
GOOGLE_TOKEN_FILE=path/to/token.json
