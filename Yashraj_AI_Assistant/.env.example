# Example environment variables for local development (placeholders only)
ENVIRONMENT=development
API_HOST=127.0.0.1
API_PORT=5000
# Replace with your local dev database URL. For simple local runs you can use SQLite:
# DATABASE_URL=sqlite+aiosqlite:///./dev_local.db
DATABASE_URL=your_database_url_here
APP_TIMEZONE=Asia/Kolkata
JWT_SECRET_KEY=your_jwt_secret_here
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=${REDIS_URL}
# Google / LLM
GOOGLE_API_KEY=your_gemini_api_key_here
GOOGLE_CLIENT_SECRETS_FILE=path/to/credentials.json
GOOGLE_TOKEN_FILE=path/to/token.json
ENABLE_JWT_AUTH=false
STARTUP_VALIDATE_GOOGLE_AUTH=false
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=0.3
LLM_TIMEOUT_SECONDS=1.5
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
RATE_LIMIT_PER_MINUTE=60
